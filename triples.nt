vgws:NOC2024 vgws:issuedOn "2024-01-12" .
vgws:NOC2024 vgws:expiresOn "2027-01-11" .
vgws:NOC2024 vgws:validityYears "3" .
vgws:NOC2024 vgws:hasCondition vgws:NOCCondition1 .
vgws:NOCCondition1 rdfs:label "Condition 1" .
vgws:NOCCondition1 vgws:requirement "Adherence to Sections 18 and 19 of the Right of Children to Free and Compulsory Education Act, 2009." .
vgws:NOC2024 vgws:hasCondition vgws:NOCCondition2 .
vgws:NOCCondition2 rdfs:label "Condition 2" .
vgws:NOCCondition2 vgws:requirement "Strict adherence to Section 12(1)(C) of the RTE Act, 2009 and Maharashtra RTE Rules 2011 (reserved seats)." .
vgws:NOC2024 vgws:hasCondition vgws:NOCCondition3 .
vgws:NOCCondition3 rdfs:label "Condition 3" .
vgws:NOCCondition3 vgws:requirement "Mandatory integration of 'Divyang' (Special Needs) students in every class, per Resolution No. Mise 2015/(119-A)/SD-6 dated 8th January 2016." .
vgws:NOC2024 vgws:hasCondition vgws:NOCCondition4 .
vgws:NOCCondition4 rdfs:label "Condition 4" .
vgws:NOCCondition4 vgws:requirement "Compliance with all state Educational Acts, Rules, and Policies issued periodically." .
vgws:NOC2024 vgws:hasCondition vgws:NOCCondition5 .
vgws:NOCCondition5 rdfs:label "Condition 5" .
vgws:NOCCondition5 vgws:requirement "Mandatory use of State Board or respective Board curriculum for Standard I to VIII." .
vgws:NOC2024 vgws:hasCondition vgws:NOCCondition6 .
vgws:NOCCondition6 rdfs:label "Condition 6" .
vgws:NOCCondition6 vgws:requirement "Compulsory instruction of the Marathi language as a subject from Standard I to X." .
vgws:NOC2024 vgws:hasCondition vgws:NOCCondition7 .
vgws:NOCCondition7 rdfs:label "Condition 7" .
vgws:NOCCondition7 vgws:requirement "Staff salaries must meet or exceed Schedule 'C' of the Maharashtra Employees of Private Schools (Conditions of Service) Regulation Act, 1981." .
vgws:NOC2024 vgws:hasCondition vgws:NOCCondition8 .
vgws:NOCCondition8 rdfs:label "Condition 8" .
vgws:NOCCondition8 vgws:requirement "Compliance with traffic/safety guidelines and fire protection codes per the National Building Code of India, Part-IV Fire 1997." .
vgws:NOC2024 vgws:hasCondition vgws:NOCCondition9 .
vgws:NOCCondition9 rdfs:label "Condition 9" .
vgws:NOCCondition9 vgws:requirement "Mandatory conduct of 3 tests annually for students up to Standard VIII, with achievement data recorded in the SARAL database." .
vgws:NOC2024 vgws:hasCondition vgws:NOCCondition10 .
vgws:NOCCondition10 rdfs:label "Condition 10" .
vgws:NOCCondition10 vgws:requirement "Regular child-wise data entry into SARAL and U-DISE as demanded by State Authorities." .
vgws:NOC2024 vgws:hasCondition vgws:NOCCondition11 .
vgws:NOCCondition11 rdfs:label "Condition 11" .
vgws:NOCCondition11 vgws:requirement "Compliance with the Maharashtra Educational Institutions (Regulation of Fees) Act, 2011." .
vgws:NOC2024 vgws:hasCondition vgws:NOCCondition12 .
vgws:NOCCondition12 rdfs:label "Condition 12" .
vgws:NOCCondition12 vgws:requirement "Compulsory teaching of Indian History and specifically History related to Maharashtra." .
vgws:NOC2024 vgws:hasCondition vgws:NOCCondition13 .
vgws:NOCCondition13 rdfs:label "Condition 13" .
vgws:NOCCondition13 vgws:requirement "Formation of a Complaint Redressal Committee per the Woman and Child Department government resolution dated 19.6.2014." .
vgws:NOC2024 vgws:hasCondition vgws:NOCCondition14 .
vgws:NOCCondition14 rdfs:label "Condition 14" .
vgws:NOCCondition14 vgws:requirement "The fee structure must be published on the official Government RTE portal." .
