vgws:NOCCondition16 rdfs:label "Condition 16" .
vgws:NOCCondition16 vgws:requirement "The State retains the right to withdraw the NOC at any time without notice for rule deviation." .
vgws:NOC2024 vgws:hasCondition vgws:NOCCondition17 .
